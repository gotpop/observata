{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-contact-details",
    "title": "Card Contact Details",
    "category": "theme",
    "description": "Contact information block with phone, email and address.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "phone": {
            "type": "string",
            "default": "+44 (0) 20 1234 5678"
        },
        "email": {
            "type": "string",
            "default": "info@observata.com"
        },
        "address": {
            "type": "string",
            "default": "London, United Kingdom"
        }
    },
    "editorScript": "file:../../build/index.js",
    "editorStyle": "file:../../build/index.css",
    "viewStyle": [
        "file:card-contact-details.css"
    ],
    "example": {
        "attributes": {
            "phone": "+44 (0) 20 1234 5678",
            "email": "info@observata.com",
            "address": "London, United Kingdom"
        }
    }
}
