{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-geo",
    "title": "Card with Geo Icon",
    "category": "theme",
    "description": "A feature card with a geometric icon, used inside the Intro block.",
    "parent": [
        "observata/intro-home",
        "observata/grid-cards-geo"
    ],
    "supports": {
        "html": false,
        "reusable": false
    },
    "attributes": {
        "cardTitle": {
            "type": "string",
            "default": ""
        },
        "cardText": {
            "type": "string",
            "default": ""
        },
        "iconGeo": {
            "type": "string",
            "default": "24"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../../build/index.js",
    "style": "file:card-geo.css",
    "example": {
        "attributes": {
            "cardTitle": "Feature Title",
            "cardText": "Description of the feature and its benefits.",
            "iconGeo": "24"
        }
    }
}