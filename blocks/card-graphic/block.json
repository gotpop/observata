{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-graphic",
    "title": "Card with Graphic",
    "category": "theme",
    "description": "A single-column section with an SVG graphic illustration and accompanying text content.",
    "supports": {
        "html": false
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": ""
        },
        "bodyText": {
            "type": "string",
            "default": ""
        },
        "graphic": {
            "type": "string",
            "default": "ribbon-star"
        },
        "graphicPosition": {
            "type": "string",
            "default": "left"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "editorStyle": "file:../../build/index.css",
    "style": "file:card-graphic.css"
}