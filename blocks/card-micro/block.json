{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-micro",
    "title": "Card Micro",
    "category": "theme",
    "description": "A small card with title and description, used inside the Observability block.",
    "parent": [
        "observata/observability"
    ],
    "supports": {
        "html": false,
        "reusable": false
    },
    "attributes": {
        "cardTitle": {
            "type": "string",
            "default": ""
        },
        "cardDescription": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": "file:card-micro.css"
}