{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-swoosh-icon",
    "title": "Card with Swoosh Background",
    "category": "theme",
    "description": "A benefit card with swoosh gradient background and numbered icon.",
    "supports": {
        "html": false,
        "reusable": false
    },
    "parent": [
        "observata/cards-grid",
        "observata/cards-triple"
    ],
    "attributes": {
        "cardTitle": {
            "type": "string",
            "default": ""
        },
        "cardText": {
            "type": "string",
            "default": ""
        },
        "iconNumber": {
            "type": "string",
            "default": "01"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": "file:card-swoosh-icon.css"
}
