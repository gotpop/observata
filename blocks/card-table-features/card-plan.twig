{#
  Card Plan partial — renders a single plan card.
  Variables: plan_name, plan_price, plan_description, highlighted (bool)
#}
{% set classes = 'card-plan' ~ (highlighted ? ' card-plan-highlighted') %}

<article class="{{ classes }}">
	<h3 class="plan-title">
		{{ plan_name }}
	</h3>
	<span class="plan-price">{{ plan_price }}</span>
	<p class="plan-description">
		{{ plan_description }}
	</p>
</article>
