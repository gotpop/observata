{#
  Card Table Features - comparison table with title, subtitle, plan cards, and feature rows.
  Inner blocks (observata/element-table-features-row) render as table rows.
#}

{% set show_plan_cards = attributes.showPlanCards is not defined
	or attributes.showPlanCards == true
%}
{% set featured_plan = attributes.featuredPlan|default(2) %}

<section class="card-table-features" data-observe="true" data-threshold="0.2">
	{% if show_plan_cards %}
		<card-plans class="card-plans">
			{% for i in 1..3 %}
				{% include 'card-table-features/card-plan.twig' with {
					plan_name: attribute(attributes, 'plan' ~ i ~ 'Name'),
					plan_price: attribute(attributes, 'plan' ~ i ~ 'Price'),
					plan_description: attribute(attributes, 'plan' ~ i ~ 'Description'),
					highlighted: i == featured_plan,
					plan_icon: attribute(attributes, 'plan' ~ i ~ 'Icon'),
					show_read_more: attribute(attributes, 'plan' ~ i ~ 'ShowReadMore'),
					read_more_text: attribute(attributes, 'plan' ~ i ~ 'ReadMoreText'),
					read_more_url: attribute(attributes, 'plan' ~ i ~ 'ReadMoreUrl')
				} %}
			{% endfor %}
		</card-plans>
	{% endif %}
	<table-outer class="table-outer">
		<table-inner class="table-inner">
			<table class="table-features">
				<thead>
					<tr class="row row-head">
						<th class="cell cell-head">
							Features
						</th>
						<th class="cell cell-head">
							{{ attributes.plan1Name|default('')|strip_html }}
						</th>
						<th class="cell cell-head">
							{{ attributes.plan2Name|default('')|strip_html }}
						</th>
						<th class="cell cell-head">
							{{ attributes.plan3Name|default('')|strip_html }}
						</th>
					</tr>
				</thead>
				<tbody>
					{{ content|raw }}
				</tbody>
			</table>
		</table-inner>
	</table-outer>
</section>
