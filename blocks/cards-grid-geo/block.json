{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/cards-grid-geo",
    "title": "Cards Grid Geo",
    "category": "theme",
    "description": "Grid section with geo card blocks. Add Card with Geo Icon blocks inside.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "introText": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:cards-grid-geo.css",
        "file:../cards/card-geo/card-geo.css"
    ],
    "editorStyle": [
        "file:cards-grid-geo.css",
        "file:../../build/index.css"
    ]
}