{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/cards-grid-graphic",
    "title": "Cards Grid Graphic",
    "category": "theme",
    "description": "A section containing multiple Card with Graphic blocks stacked vertically.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "introText": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:cards-grid-graphic.css",
        "file:../cards/card-graphic/card-graphic.css"
    ],
    "editorStyle": [
        "file:cards-grid-graphic.css",
        "file:../../build/index.css"
    ]
}