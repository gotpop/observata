{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-geo-list",
    "title": "Card with Geo Icon & List",
    "category": "theme",
    "description": "A feature card with a geometric icon and a list of items, used inside the Intro block.",
    "parent": [
        "observata/intro",
        "observata/intro-page",
        "observata/grid-cards-geo",
        "observata/grid-cards-graphic"
    ],
    "supports": {
        "html": false,
        "reusable": false
    },
    "attributes": {
        "cardTitle": {
            "type": "string",
            "default": ""
        },
        "listItem1": {
            "type": "string",
            "default": ""
        },
        "listItem2": {
            "type": "string",
            "default": ""
        },
        "iconGeo": {
            "type": "string",
            "default": "24"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../../build/index.js",
    "style": "file:card-geo-list.css"
}