{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-geo-shader",
    "title": "Card with Geo Shader",
    "category": "theme",
    "description": "A benefit card with swoosh gradient background and numbered icon.",
    "parent": [
        "observata/grid-cards"
    ],
    "supports": {
        "html": false,
        "reusable": false
    },
    "attributes": {
        "cardTitle": {
            "type": "string",
            "default": ""
        },
        "cardText": {
            "type": "string",
            "default": ""
        },
        "iconNumber": {
            "type": "string",
            "default": "01"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../../build/index.js",
    "style": "file:card-geo-shader.css"
}