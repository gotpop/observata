{% set card_title = attributes.cardTitle|default('') %}
{% set card_text = attributes.cardText|default('') %}
{% set icon_geo = attributes.iconGeo|default('24') %}
{% set background_graphic = attributes.backgroundGraphic|default('') %}

<article class="card-geo-tech icon-{{ icon_geo }}">
	{% if background_graphic %}
		<div class="card-geo-tech-graphic" aria-hidden="true">
			{% include 'views/graphics/tech/' ~ background_graphic ~ '.twig' %}
		</div>
	{% endif %}
	<div class="intro-card-icon" aria-hidden="true">
		{% include 'icons/geo/' ~ icon_geo ~ '.twig' %}
	</div>
	<div class="intro-card-body">
		<h3 class="intro-card-title">{{ card_title|esc_html }}</h3>
		<p class="intro-card-text">{{ card_text|wp_kses_post }}</p>
	</div>
</article>
