{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-rich-text",
    "title": "Card Rich Text",
    "category": "theme",
    "description": "A card with title and rich text content.",
    "parent": [
        "observata/grid-cards-rich-text"
    ],
    "supports": {
        "html": false,
        "reusable": false
    },
    "attributes": {
        "cardTitle": {
            "type": "string",
            "default": ""
        },
        "cardContent": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../../build/index.js",
    "style": "file:card-rich-text.css",
    "example": {
        "attributes": {
            "cardTitle": "Card Title",
            "cardContent": "Rich text content with <strong>formatted</strong> text and other styling."
        }
    }
}