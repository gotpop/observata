{#
  Card Rich Text - displays a card with title and rich text content.
#}

{% set card_title = attributes.cardTitle|default('') %}
{% set card_content = attributes.cardContent|default('') %}

<div class="card-rich-text">
	{% if card_title %}
		<h3 class="card-rich-text__title">{{ card_title|wp_kses_post }}</h3>
	{% endif %}
	{% if card_content %}
		<div class="card-rich-text__content">{{ card_content|wp_kses_post }}</div>
	{% endif %}
</div>
