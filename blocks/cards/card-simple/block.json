{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/card-simple",
    "title": "Card Simple",
    "category": "theme",
    "description": "A simple card with geo icon, title and description.",
    "attributes": {
        "title": {
            "type": "string",
            "default": ""
        },
        "description": {
            "type": "string",
            "default": ""
        },
        "iconGeo": {
            "type": "string",
            "default": "24"
        }
    },
    "supports": {
        "html": false
    },
    "textdomain": "observata"
}