{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/contact-details",
    "title": "Contact Details",
    "category": "theme",
    "description": "Contact information block with phone, email and address.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "phone": {
            "type": "string",
            "default": "+44 (0) 20 1234 5678"
        },
        "email": {
            "type": "string",
            "default": "info@observata.com"
        },
        "address": {
            "type": "string",
            "default": "London, United Kingdom"
        }
    },
    "editorScript": "file:../../build/index.js",
    "editorStyle": [
        "file:contact-details.css",
        "file:../../build/index.css"
    ],
    "style": [
        "file:contact-details.css"
    ]
}