{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/element-table-features-row",
    "title": "Element Features Row",
    "category": "theme",
    "description": "A table row with a feature name and check/dash values for each plan.",
    "parent": [
        "observata/card-table-features"
    ],
    "supports": {
        "html": false,
        "reusable": false
    },
    "attributes": {
        "featureName": {
            "type": "string",
            "default": "Feature"
        },
        "plan1Value": {
            "type": "string",
            "default": "check"
        },
        "plan2Value": {
            "type": "string",
            "default": "check"
        },
        "plan3Value": {
            "type": "string",
            "default": "dash"
        }
    },
    "editorScript": "file:../../../build/index.js",
    "style": "file:element-table-features-row.css",
    "example": {
        "attributes": {
            "featureName": "Feature",
            "plan1Value": "check",
            "plan2Value": "check",
            "plan3Value": "dash"
        }
    }
}