{% set locations = attributes.locations|default('Denmark | Sweden | Finland | Norway') %}
{% set copyright = attributes.copyright|default('© Observata AB 2026') %}
{% set contact_email = attributes.contactEmail|default('sales@observata.com') %}
{% set contact_address = attributes.contactAddress|default('Trade Center Halmstad Box 837 SE - 30118 Halmstad Sweden') %}

<footer id="footer" role="contentinfo">
    <div class="footer-content">
        <div class="footer-top">
            <div class="footer-logo">
                <a href="{{ function('home_url', '/') }}"
                    title="{{ function('get_bloginfo', 'name')|esc_attr }}">
                    <h1>Observata</h1>
                </a>
            </div>

            <div class="footer-links">
                <a href="https://observata.com/managed-detection-and-response-services/"
                    class="footer-link">Services</a>
                <a href="https://observata.com/pricing/"
                    class="footer-link">Pricing</a>
                <a href="https://observata.com/resources/"
                    class="footer-link">Resources</a>
                <a href="https://observata.com/about-us/"
                    class="footer-link">About Us</a>
                <a href="https://observata.com/contact-us/"
                    class="footer-link">Contact Us</a>
                <a href="https://observata.com/observability-overview/"
                    class="footer-link">Observability</a>
                <a href="https://observata.com/cybersecurity-overview/"
                    class="footer-link">Cybersecurity</a>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-locations">
                <p>{{ locations|esc_html }}</p>
            </div>

            <div class="footer-contact">
                <div class="footer-contact-item">
                    <p class="footer-label">Email</p>
                    <p class="footer-value"><a
                            href="mailto:{{ contact_email|esc_html }}">{{ contact_email|esc_html }}</a></p>
                </div>

                <div class="footer-contact-item">
                    <p class="footer-label">Address</p>
                    <p class="footer-value">{{ contact_address|esc_html }}</p>
                </div>
            </div>

            <div class="footer-copyright">
                <p>{{ copyright|esc_html }}</p>
            </div>
        </div>
    </div>
</footer>