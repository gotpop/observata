{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/grid-cards",
    "title": "Grid Cards",
    "category": "theme",
    "description": "Six-card grid section.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "introText": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:grid-cards.css",
        "file:../cards/card-swoosh-icon/card-swoosh-icon.css"
    ],
    "editorStyle": [
        "file:grid-cards.css",
        "file:../cards/card-swoosh-icon/card-swoosh-icon.css",
        "file:../../build/index.css"
    ]
}