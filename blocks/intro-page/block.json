{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/intro-page",
    "title": "Intro Page",
    "category": "theme",
    "description": "Sub-page intro section with feature cards containing lists, icons, and a graphic element.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "graphic": {
            "type": "string",
            "default": "connected-dots"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "editorStyle": [
        "file:intro-page.css",
        "file:../../build/index.css"
    ],
    "style": [
        "file:intro-page.css",
        "file:../cards/card-geo-list/card-geo-list.css"
    ]
}