{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/intro",
    "title": "Intro",
    "category": "theme",
    "description": "Intro section with logo strip and feature cards. Add Card with Geo Icon blocks inside.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        }
    },
    "providesContext": {
        "iconGeo": "iconGeo"
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:intro.css",
        "file:../card-geo/card-geo.css"
    ],
    "editorStyle": [
        "file:intro.css",
        "file:../../build/index.css"
    ]
}