{% set section_title = attributes.sectionTitle|default('Being observed is not the same as being observable') %}
{% set intro_text = attributes.introText|default('Most observability stacks were built for dashboards and not decisions.') %}

{% set cards = [
	{ title: 'Alert fatigue', description: 'Too many noisy alerts hide the incidents that matter most.' },
	{ title: 'Cost sprawl', description: 'Unmanaged ingestion and retention policies inflate platform spend.' },
	{ title: 'Blind spots', description: 'Disconnected logs, metrics, and traces prevent fast root-cause analysis.' }
] %}

<section class="block-observability">
	<block-content class="block-content">
		{% include 'observability/section-intro.twig' %}

		<article class="card-large">
			<div class="cards-micro">
				{% for card in cards %}
					{% include 'observability/card-micro.twig' %}
				{% endfor %}
			</div>
		</article>
	</block-content>
</section>
