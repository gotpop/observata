{#
  Plan Features Table - comparison table with title, subtitle, plan cards.
#}

{% set show_plan_cards = attributes.showPlanCards is not defined
	or attributes.showPlanCards == true
%}

<section class="plan-features-table">
	{% if show_plan_cards %}
		<plan-cards class="plan-features-table__cards">
			<div class="plan-card">
				<h3 class="plan-title">
					{{ attributes.plan1Name }}
				</h3>
				<span class="plan-price">{{ attributes.plan1Price }}</span>
				<p class="plan-description">
					{{ attributes.plan1Description }}
				</p>
			</div>
			<div class="plan-card plan-card-highlighted">
				<h3 class="plan-title">
					{{ attributes.plan2Name }}
				</h3>
				<span class="plan-price">{{ attributes.plan2Price }}</span>
				<p class="plan-description">
					{{ attributes.plan2Description }}
				</p>
			</div>
			<div class="plan-card">
				<h3 class="plan-title">
					{{ attributes.plan3Name }}
				</h3>
				<span class="plan-price">{{ attributes.plan3Price }}</span>
				<p class="plan-description">
					{{ attributes.plan3Description }}
				</p>
			</div>
		</plan-cards>
	{% endif %}

	<div class="plan-features-table__table-wrapper">
		<table class="plan-features-table__table">
			<thead>
				<tr class="plan-features-table__head-row">
					<th class="plan-features-table__head-cell">
						Features
					</th>
					<th class="plan-features-table__head-cell">
						{{ attributes.plan1Name }}
					</th>
					<th class="plan-features-table__head-cell">
						{{ attributes.plan2Name }}
					</th>
					<th class="plan-features-table__head-cell">
						{{ attributes.plan3Name }}
					</th>
				</tr>
			</thead>
			<tbody>
				{{ content }}
			</tbody>
		</table>
	</div>
</section>
