{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/grid-cards-geo-tech",
    "title": "Cards Grid Geo Tech",
    "category": "theme",
    "description": "Grid section with geo-tech cards. Card data is stored as block attributes and rendered dynamically.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "introText": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:grid-cards-geo-tech.css",
        "file:../cards/card-geo-tech/card-geo-tech.css",
        "file:../template/section-intro/section-intro.css"
    ],
    "editorStyle": [
        "file:grid-cards-geo-tech.css",
        "file:../template/section-intro/section-intro.css",
        "file:../../build/index.css"
    ]
}