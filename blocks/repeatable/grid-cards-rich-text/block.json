{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/grid-cards-rich-text",
    "title": "Grid Cards Rich Text",
    "category": "theme",
    "description": "A grid section containing rich text cards.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "introText": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:grid-cards-rich-text.css",
        "file:../cards/card-rich-text/card-rich-text.css",
        "file:../template/section-intro/section-intro.css"
    ],
    "editorStyle": [
        "file:grid-cards-rich-text.css",
        "file:../template/section-intro/section-intro.css",
        "file:../../build/index.css"
    ],
    "example": {
        "attributes": {
            "sectionTitle": "Our Articles",
            "introText": "Explore our latest insights and updates."
        }
    }
}