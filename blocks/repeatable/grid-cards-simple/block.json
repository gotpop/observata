{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/grid-cards-simple",
    "title": "Grid Cards Simple",
    "category": "theme",
    "description": "3 service cards in grid layout.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": ""
        },
        "card1Title": {
            "type": "string",
            "default": "Search as a Service"
        },
        "card1Text": {
            "type": "string",
            "default": "Enable your employees to securely and fast locate information across all internal systems."
        },
        "card1IconNumber": {
            "type": "string",
            "default": "01"
        },
        "card2Title": {
            "type": "string",
            "default": "MDR as a Service"
        },
        "card2Text": {
            "type": "string",
            "default": "We protect your critical assets 24/7. Detecting threats, responding fast and preventing attacks."
        },
        "card2IconNumber": {
            "type": "string",
            "default": "02"
        },
        "card3Title": {
            "type": "string",
            "default": "Observability as a Service"
        },
        "card3Text": {
            "type": "string",
            "default": "Powered by Elastic. Managed by experts. Detect early, respond fast."
        },
        "card3IconNumber": {
            "type": "string",
            "default": "03"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "editorStyle": "file:../../build/index.css",
    "style": "file:grid-cards-simple.css"
}