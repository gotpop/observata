{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/plan-features-table",
    "title": "Plan Features Table",
    "category": "theme",
    "description": "A features comparison table with title, subtitle, plan cards, and draggable feature rows.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": "Compare plans & features"
        },
        "sectionSubtitle": {
            "type": "string",
            "default": "Find the right plan for your team."
        },
        "plan1Name": {
            "type": "string",
            "default": "Assisted"
        },
        "plan1Price": {
            "type": "string",
            "default": "0kr"
        },
        "plan1Description": {
            "type": "string",
            "default": "Lorem ipsum dolor sit amet."
        },
        "plan2Name": {
            "type": "string",
            "default": "Operated"
        },
        "plan2Price": {
            "type": "string",
            "default": "50kr"
        },
        "plan2Description": {
            "type": "string",
            "default": "Lorem ipsum dolor sit amet."
        },
        "plan3Name": {
            "type": "string",
            "default": "Serviced"
        },
        "plan3Price": {
            "type": "string",
            "default": "100kr"
        },
        "plan3Description": {
            "type": "string",
            "default": "Lorem ipsum dolor sit amet."
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:plan-features-table.css",
        "file:../cards/plan-features-row/plan-features-row.css"
    ],
    "editorStyle": [
        "file:plan-features-table.css",
        "file:../../build/index.css"
    ],
    "example": {
        "attributes": {
            "sectionTitle": "Compare plans & features",
            "sectionSubtitle": "Find the right plan for your team.",
            "plan1Name": "Assisted",
            "plan1Price": "0kr",
            "plan1Description": "Lorem ipsum dolor sit amet.",
            "plan2Name": "Operated",
            "plan2Price": "50kr",
            "plan2Description": "Lorem ipsum dolor sit amet.",
            "plan3Name": "Serviced",
            "plan3Price": "100kr",
            "plan3Description": "Lorem ipsum dolor sit amet."
        }
    }
}