{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/plan-features-table",
    "title": "Plan Features Table",
    "category": "theme",
    "description": "A features comparison table with title, subtitle, plan cards, and draggable feature rows.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": "Compare plans & features"
        },
        "sectionSubtitle": {
            "type": "string",
            "default": "Find the right plan for your team."
        },
        "plan1Name": {
            "type": "string",
            "default": "Starter"
        },
        "plan1Price": {
            "type": "string",
            "default": "$0"
        },
        "plan1Description": {
            "type": "string",
            "default": "For individuals getting started."
        },
        "plan2Name": {
            "type": "string",
            "default": "Pro"
        },
        "plan2Price": {
            "type": "string",
            "default": "$49"
        },
        "plan2Description": {
            "type": "string",
            "default": "For teams that need more power."
        },
        "plan3Name": {
            "type": "string",
            "default": "Enterprise"
        },
        "plan3Price": {
            "type": "string",
            "default": "Custom"
        },
        "plan3Description": {
            "type": "string",
            "default": "For organisations with complex needs."
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:plan-features-table.css",
        "file:../cards/plan-features-row/plan-features-row.css"
    ],
    "editorStyle": [
        "file:plan-features-table.css",
        "file:../../build/index.css"
    ]
}