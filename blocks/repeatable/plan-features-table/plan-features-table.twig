{#
  Plan Features Table - comparison table with title, subtitle, plan cards, and feature rows.
  Inner blocks (observata/plan-features-row) render as table rows.
#}

<section class="plan-features-table">
	<div class="plan-features-table__header">
		<h2 class="plan-features-table__title">{{ attributes.sectionTitle }}</h2>
		<p class="plan-features-table__subtitle">{{ attributes.sectionSubtitle }}</p>
	</div>

	<div class="plan-features-table__cards">
		<div class="plan-features-table__card">
			<h3 class="plan-features-table__card-name">{{ attributes.plan1Name }}</h3>
			<span class="plan-features-table__card-price">{{ attributes.plan1Price }}</span>
			<p class="plan-features-table__card-desc">{{ attributes.plan1Description }}</p>
		</div>
		<div class="plan-features-table__card plan-features-table__card--highlighted">
			<h3 class="plan-features-table__card-name">{{ attributes.plan2Name }}</h3>
			<span class="plan-features-table__card-price">{{ attributes.plan2Price }}</span>
			<p class="plan-features-table__card-desc">{{ attributes.plan2Description }}</p>
		</div>
		<div class="plan-features-table__card">
			<h3 class="plan-features-table__card-name">{{ attributes.plan3Name }}</h3>
			<span class="plan-features-table__card-price">{{ attributes.plan3Price }}</span>
			<p class="plan-features-table__card-desc">{{ attributes.plan3Description }}</p>
		</div>
	</div>

	<div class="plan-features-table__table-wrapper">
		<table class="plan-features-table__table">
			<thead>
				<tr class="plan-features-table__head-row">
					<th class="plan-features-table__head-cell">Features</th>
					<th class="plan-features-table__head-cell">{{ attributes.plan1Name }}</th>
					<th class="plan-features-table__head-cell">{{ attributes.plan2Name }}</th>
					<th class="plan-features-table__head-cell">{{ attributes.plan3Name }}</th>
				</tr>
			</thead>
			<tbody>
				{{ content }}
			</tbody>
		</table>
	</div>
</section>
