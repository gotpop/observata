{% set graphic = attributes.graphic|default('ribbon-star') %}
{% set graphic_position = attributes.graphicPosition|default('left') %}
{% set section_bg_colour = attributes.sectionBgColour|default('white') %}

<section
	class="section-block block-section-card-and-graphic"
	data-observe="true"
	data-threshold="1"
	data-margin-top="400px"
	data-margin-bottom="0px"
	style="--section-bg-colour: var(--surface-{{ section_bg_colour }});">
	<block-content class="block-content position-{{ graphic_position }}">
		{{ content|raw }}

		<graphic-tech
			class="graphic-sphere graphic-{{ graphic }}"
			aria-hidden="true"
			style="--mask-image: url('{{ theme.link }}/assets/svg/spheres/sphere-{{
			graphic
			}}.svg');"></graphic-tech>
	</block-content>
</section>
