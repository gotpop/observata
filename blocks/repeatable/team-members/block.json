{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/team-members",
    "title": "Team Members",
    "category": "theme",
    "description": "A team members section with a grid of team member cards.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "sectionTitle": {
            "type": "string",
            "default": "Meet the team"
        },
        "introText": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:team-members.css",
        "file:../cards/card-team-member/card-team-member.css",
        "file:../template/section-intro/section-intro.css"
    ],
    "editorStyle": [
        "file:team-members.css",
        "file:../template/section-intro/section-intro.css",
        "file:../../build/index.css"
    ],
    "example": {
        "attributes": {
            "sectionTitle": "Meet the team",
            "introText": "Get to know the experts behind our solutions."
        }
    }
}