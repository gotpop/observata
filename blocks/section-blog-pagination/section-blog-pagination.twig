<nav class="section-blog-pagination">
	<div class="section-blog-pagination__container">
		{% if prev_post %}
			<a href="{{ prev_post.guid }}" class="section-blog-pagination__link section-blog-pagination__link--prev">
				<span class="section-blog-pagination__arrow section-blog-pagination__arrow--left">&larr;</span>
				<span class="section-blog-pagination__title">{{ prev_post.post_title }}</span>
			</a>
		{% endif %}

		{% if next_post %}
			<a href="{{ next_post.guid }}" class="section-blog-pagination__link section-blog-pagination__link--next">
				<span class="section-blog-pagination__title">{{ next_post.post_title }}</span>
				<span class="section-blog-pagination__arrow section-blog-pagination__arrow--right">&rarr;</span>
			</a>
		{% endif %}
	</div>
</nav>
