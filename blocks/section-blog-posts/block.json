{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/section-blog-posts",
    "title": "Section Blog Posts",
    "category": "theme",
    "description": "Displays the latest blog posts in a responsive card grid.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "postsPerPage": {
            "type": "number",
            "default": 10
        },
        "sectionBgColour": {
            "type": "string",
            "default": "white",
            "enum": [
                "white",
                "grey",
                "gradient"
            ]
        }
    },
    "editorScript": "file:../../build/index.js",
    "editorStyle": "file:../../build/index.css",
    "viewStyle": [
        "file:section-blog-posts.css",
        "file:section-blog-card.css"
    ],
    "example": {
        "attributes": {
            "postsPerPage": 10
        }
    }
}
