{% set title = attributes.title|default('') %}
{% set text = attributes.text|default('') %}
{% set cta_text = attributes.ctaText|default('') %}
{% set cta_url = attributes.ctaUrl|default('') %}
{% set section_bg_colour = attributes.sectionBgColour|default('white') %}

<section
	class="section-block section-cta"
	data-threshold="1"
	data-observe="true"
	data-margin-top="200px"
	style="--section-bg-colour: var(--surface-{{ section_bg_colour }});">
	{% include 'graphics/tech/swooping-lines-cta.twig' %}
	<block-content class="block-content">
		<div class="content-cta">
			{% if title %}
				<h3 class="heading-lg">
					{{ title|strip_html }}
				</h3>
			{% endif %}

			{% if text %}
				<p class="body-md">
					{{ text|strip_html }}
				</p>
			{% endif %}

			{% if cta_text and cta_url %}
				<a class="cta-secondary cta-section" href="{{ cta_url|esc_url }}">
					<span>{{ cta_text|strip_html }}</span>
					{% include 'icons/lucide/arrow-right.twig' %}
				</a>
			{% endif %}
		</div>
	</block-content>
</section>
