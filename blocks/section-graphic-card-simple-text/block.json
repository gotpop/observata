{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/section-graphic-card-simple-text",
    "title": "Section Graphic Card Simple Text",
    "category": "theme",
    "description": "A single Card Text Simple block with an optional background graphic.",
    "supports": {
        "html": false,
        "multiple": true
    },
    "attributes": {
        "backgroundGraphic": {
            "type": "string",
            "default": ""
        },
        "sectionBgColour": {
            "type": "string",
            "default": "white",
            "enum": [
                "white",
                "grey"
            ]
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "style": [
        "file:section-graphic-card-simple-text.css",
        "file:../card-text-simple/card-text-simple.css"
    ],
    "editorStyle": [
        "file:section-graphic-card-simple-text.css",
        "file:../../build/index.css"
    ],
    "example": {
        "attributes": {
            "backgroundGraphic": ""
        }
    }
}