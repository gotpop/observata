{% set section_title = attributes.sectionTitle|default('') %}
{% set intro_text = attributes.introText|default('') %}
{% set cta_text = attributes.ctaText|default('') %}
{% set cta_url = attributes.ctaUrl|default('') %}
{% set phase1_number = attributes.phase1Number|default('01') %}
{% set phase1_title = attributes.phase1Title|default('') %}
{% set phase1_item_title1 = attributes.phase1ItemTitle1|default('') %}
{% set phase1_text1 = attributes.phase1Text1|default('') %}
{% set phase1_item_title2 = attributes.phase1ItemTitle2|default('') %}
{% set phase1_text2 = attributes.phase1Text2|default('') %}
{% set phase2_number = attributes.phase2Number|default('02') %}
{% set phase2_title = attributes.phase2Title|default('The partnership') %}
{% set phase2_item_title1 = attributes.phase2ItemTitle1|default('') %}
{% set phase2_text1 = attributes.phase2Text1|default('') %}
{% set phase2_text2 = attributes.phase2Text2|default('') %}
{% set section_bg_colour = attributes.sectionBgColour|default('white') %}

<section
	class="section-block block-section-partnership"
	data-threshold="0.6"
	data-observe="true"
	data-margin-top="0px"
	data-bg="{{ section_bg_colour }}"
	style="--section-bg-colour: var(--surface-{{ section_bg_colour }});">
	{% include 'graphics/tech/swooping-lines.twig' %}
	<block-content class="block-content">
		{% include 'template/section-intro/section-intro.twig' with {
			attributes: {
				sectionTitle: section_title,
				introText: intro_text,
				textAlign: 'center'
			}
		} %}
		<block-body class="block-body">
			<article class="phase phase-one">
				<header-phase class="phase-header">
					<h3 class="phase-title">
						{{ phase1_title }}
					</h3>
				</header-phase>
				<content-phase class="phase-content">
					<item-phase class="phase-item">
						<h4 class="heading-sm phase-item-title">
							{{ phase1_item_title1 }}
						</h4>
						<p class="body-sm">
							{{ phase1_text1 }}
						</p>
					</item-phase>
					<item-phase class="phase-item">
						<h4 class="heading-sm phase-item-title">
							{{ phase1_item_title2 }}
						</h4>
						<p class="body-sm">
							{{ phase1_text2 }}
						</p>
					</item-phase>
				</content-phase>
			</article>
			<article class="phase phase-two">
				<header-phase class="phase-header">
					<h3 class="phase-title">
						{{ phase2_title }}
					</h3>
				</header-phase>
				<content-phase class="phase-content">
					<item-phase class="phase-item">
						<h4 class="heading-sm phase-item-title">
							{{ phase2_item_title1 }}
						</h4>
						<p class="body-sm">
							{{ phase2_text1 }}
						</p>
					</item-phase>
				</content-phase>
			</article>
			{% if cta_text %}
				<a href="{{ cta_url|esc_url }}" class="cta-secondary cta-partnership">
					<span>{{ cta_text|strip_html }}</span>
					{% include 'icons/lucide/arrow-right.twig' %}
				</a>
			{% endif %}
		</block-body>
	</block-content>
</section>
