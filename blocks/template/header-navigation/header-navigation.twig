<div class="header-navigation">
	<nav id="menu" role="navigation" aria-label="{{ function('__', 'Primary Navigation', 'observata') }}">
		<ul class="menu-list">
			{% if main_menu and main_menu.items %}
				{% for item in main_menu.items %}
					{% if item.children %}
						<li class="menu-item menu-item-has-children menu-item-{{ item.slug|esc_attr }}">
							{% if item.link == '#' %}
								<button class="menu-link menu-link--placeholder" aria-haspopup="true" aria-expanded="false" aria-controls="submenu-{{ loop.index }}">
								{% else %}
									<a href="{{ item.link }}" class="menu-link" aria-haspopup="true" aria-expanded="false" aria-controls="submenu-{{ loop.index }}">
									{% endif %}
									<span>{{ item.title|esc_html }}</span>
									<svg class="menu-arrow" width="10" height="6" viewbox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
									{% if item.link == '#' %}
									</button>
							{% else %}
								</a>
							{% endif %}
							<div class="sub-wrapper" id="submenu-{{ loop.index }}">
								<ul class="submenu">
									{% for child in item.children %}
										<li class="submenu-item menu-item-{{ child.slug|esc_attr }}">
											<a href="{{ child.link }}">{{ child.title|esc_html }}</a>
										</li>
									{% endfor %}
								</ul>
							</div>
						</li>
					{% else %}
						<li class="menu-item menu-item-{{ item.slug|esc_attr }}">
							<a href="{{ item.link }}">
								<span>{{ item.title|esc_html }}</span>
							</a>
						</li>
					{% endif %}
				{% endfor %}
			{% endif %}
		</ul>
	</nav>
</div>
