<div class="sub-menu-wrapper" id="submenu-{{ loop.index }}">
	<ul class="submenu">
		{% for child in item.children %}
			<li class="submenu-item menu-item-{{ child.slug|esc_attr }}">
				<a class="menu-anchor" href="{{ child.link|esc_url }}">
					{{ child.title|strip_html }}
				</a>
			</li>
		{% endfor %}
	</ul>
</div>
