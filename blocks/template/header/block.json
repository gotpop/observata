{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "observata/header",
    "title": "Header",
    "category": "theme",
    "description": "Header with logo and navigation dropdowns.",
    "supports": {
        "html": false,
        "multiple": false
    },
    "attributes": {
        "logo": {
            "type": "string",
            "default": ""
        },
        "services": {
            "type": "string",
            "default": "Services"
        },
        "pricing": {
            "type": "string",
            "default": "Pricing"
        },
        "resources": {
            "type": "string",
            "default": "Resources"
        },
        "about": {
            "type": "string",
            "default": "About Us"
        },
        "contact": {
            "type": "string",
            "default": "Contact Us"
        }
    },
    "render": "file:render.php",
    "editorScript": "file:../../build/index.js",
    "editorStyle": "file:../../build/index.css",
    "style": "file:header.css",
    "example": {
        "attributes": {
            "logo": "",
            "services": "Services",
            "pricing": "Pricing",
            "resources": "Resources",
            "about": "About Us",
            "contact": "Contact Us"
        }
    }
}