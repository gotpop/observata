		<style>

				svg {
				stroke-linecap: round;
				stroke-linejoin: round;
			}

			.sphere {
				fill: none;
				stroke: url(#sphere-gradient);
				stroke-width: 1px;
			}

			.line {
				fill: none;
				stroke: url(#sphere-gradient);
				stroke-width: 1px;
				stroke-dasharray: 56 24;
				animation: flow 3s linear infinite;
			}

			.dot-front {
				fill: url(#sphere-gradient);
				stroke: none;
			}

			.dot-back {
				fill: url(#sphere-gradient);
				stroke: none;
				opacity: 0.35;
			}

			@keyframes flow {
				to {
					stroke-dashoffset: -80;
				}
			}

			.line:nth-child(even) {
				animation-delay: -1.5s;
			}

			.line:nth-child(odd) {
				animation-delay: -0.5s;
			}

			@media (prefers-reduced-motion: reduce) {
				.line {
					animation: none;
					stroke-dasharray: none;
				}
			}

		</style>
