<graphic-sphere class="graphic-sphere graphic-sphere-01a" aria-hidden="true">
	<svg
		class="graphic-sphere-svg"
		height="100%"
		viewBox="-10 -10 460 460"
		width="100%"
		xmlns="http://www.w3.org/2000/svg">
		<style>

				svg {
				stroke-linecap: round;
				stroke-linejoin: round;
			}

			.sphere {
				fill: none;
				stroke: url(#sphere-gradient);
				stroke-width: 1px;
			}

			.line {
				fill: none;
				stroke: url(#sphere-gradient);
				stroke-width: 1px;
				stroke-dasharray: 56 24;
				animation: flow 3s linear infinite;
			}

			.dot-front {
				fill: url(#sphere-gradient);
				stroke: none;
			}

			.dot-back {
				fill: url(#sphere-gradient);
				stroke: none;
				opacity: 1;
			}

			@keyframes flow {
				to {
					stroke-dashoffset: -80;
				}
			}

			.line:nth-child(even) {
				animation-delay: -1.5s;
			}

			.line:nth-child(odd) {
				animation-delay: -0.5s;
			}

			@media (prefers-reduced-motion: reduce) {
				.line {
					animation: none;
					stroke-dasharray: none;
				}
			}

		</style>
