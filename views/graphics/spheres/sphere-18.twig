        .dot {
            fill: url(#sphere-gradient);
            stroke: none;
            r: 2.5px;
        }

        .dot-circle {
            fill: url(#sphere-gradient);
            r: 2.5px;
        }

        @keyframes flow {
            to {
                stroke-dashoffset: -80;
            }
        }


        .line:nth-child(even) {
            animation-delay: -1.5s;
        }

        .line:nth-child(odd) {
            animation-delay: -0.5s;
        }

        @media (prefers-reduced-motion: reduce) {
            .line {
                animation: none;
                stroke-dasharray: none;
            }
        }

