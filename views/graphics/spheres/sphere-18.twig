        }

        .line {
            fill: none;
            stroke: url(#sphere-gradient);
            stroke-width: 1px;
            stroke-dasharray: 56 24;
            /* stroke-dasharray: none !important; */
            animation: flow 3s linear infinite;
			/* animation: none !important; */
