{% extends 'base.twig' %}

{% block header %}
	{{ header | raw }}
{% endblock %}

{% block content %}
	{% if hero %}
		{{ hero | raw }}
	{% endif %}
	<content-blog id="content-blog" class="content-blog">
		{{ content | raw }}
	</content-blog>
{% endblock %}

{% block footer %}
	{{ footer | raw }}
{% endblock %}
