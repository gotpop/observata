{% extends 'base.twig' %}

{% block header %}
	{{ header|raw }}
{% endblock %}

{% block content %}
	{% if hero %}
		{{ hero|raw }}
	{% endif %}
	<content-page id="content-page" class="content-page">
		{{ content|raw }}
	</content-page>
{% endblock %}

{% block footer %}
	{{ footer|raw }}
{% endblock %}
