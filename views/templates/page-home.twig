{% extends 'base.twig' %}

{% block header %}
	{{ header | raw }}
{% endblock %}

{% block content %}
	{% if hero %}
		{{ hero | raw }}
	{% endif %}
	<content-home id="content-home" class="content-home">
		{{ content | raw }}
	</content-home>
{% endblock %}

{% block footer %}
	{{ footer | raw }}
{% endblock %}
